# ============================================================
# Bloxive V3 — Environment Variables
# ============================================================

# Discord Bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# MongoDB (requires replica set for transactions)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bloxive

# Roblox OAuth2
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=
ROBLOX_REDIRECT_URI=https://bloxive.xyz/callback

# Base URL (for OAuth redirects and asset URLs)
BASE_URL=https://bloxive.xyz

# Cloudflare R2 Storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bloxive-assets
R2_PUBLIC_URL=

# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# JWT Secret (for dashboard API auth)
JWT_SECRET=
